pipeline {
    agent any

    environment {
        BACKEND_IMAGE = "mern-backend:jenkins"
        FRONTEND_IMAGE = "mern-frontend:jenkins"
        DOCKER_REGISTRY = "your-dockerhub-username"
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo 'Checking out source code from GitHub...'
                script {
                    echo "Building commit: ${env.GIT_COMMIT}"
                    echo "Branch: ${env.GIT_BRANCH}"
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                echo 'Building Docker images...'
                script {

                    echo "Building backend image: ${BACKEND_IMAGE}"
                    sh "docker build -t ${BACKEND_IMAGE} ./server"

                    echo "Building frontend image: ${FRONTEND_IMAGE}"
                    sh """
                    docker build -t ${FRONTEND_IMAGE} ./client \
                    --build-arg VITE_API_URL=http://localhost:5001/api
                    """

                    sh "docker images | grep jenkins || true"
                }
            }
        }

        stage('Run with Docker Compose') {
            steps {
                script {
                    echo "Starting MERN stack with Docker Compose..."

                    sh 'docker compose up -d'

                    echo "Showing running containers..."
                    sh 'docker ps'

                    echo "===== Backend Logs ====="
                    sh 'docker logs backend || true'

                    echo "===== Frontend Logs ====="
                    sh 'docker logs frontend || true'
                }
            }
        }
    }
}