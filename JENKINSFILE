pipeline {
    agent any

    environment {
        // Keeping all your original variables plus the new ones for clean code
        BACKEND_IMAGE = "mern-backend:jenkins"
        FRONTEND_IMAGE = "mern-frontend:jenkins"
        DOCKER_REGISTRY = "hardiky99" 
        PORT = "5001"
        VITE_API_URL = "http://localhost:5000/api"
    }

    stages {
        stage('Checkout Code') {
            steps {
                echo 'Checking out source code from GitHub...'
                script {
                    // Using env variables to show build details in logs
                    echo "Building commit: ${env.GIT_COMMIT}"
                    echo "Branch: ${env.GIT_BRANCH}"
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                echo 'Building Docker images...'
                script {
                    echo "Building backend image: ${BACKEND_IMAGE}"
                    sh "docker build -t ${BACKEND_IMAGE} ./server"

                    echo "Building frontend image: ${FRONTEND_IMAGE}"
                    sh "docker build -t ${FRONTEND_IMAGE} ./client --build-arg VITE_API_URL=${VITE_API_URL}"

                    sh "docker images | grep jenkins"
                }
            }
        }

stage('Start Application Services') {
            steps {
                echo 'Starting MERN application...'
                script { 
                    // Permission fix
                    sh 'sudo chmod 666 /var/run/docker.sock || true'
                    
                    withCredentials([string(credentialsId: 'MONGO_URI', variable: 'DB_URL')]) {
                        // All commands stay inside this block
                        sh "echo 'MONGO_URI=${DB_URL}' > ./server/.env"
                        sh "echo 'PORT=${PORT}' >> ./server/.env"

                        sh 'docker compose up -d'
                        
                        echo "Waiting for services to start..."
                        sleep(time: 30, unit: "SECONDS")

                        sh 'docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Status}}"'
                    } // Closes Credentials
                } // Closes Script
            } // Closes Steps
        } // Closes Stage

        stage('Health Check & Testing') {
            steps {
                echo 'Running health checks...'
                script {
                    echo "Testing backend API..."
                    sh "curl -f http://localhost:${PORT}/health || { echo '❌ Backend health check failed'; exit 1; }"
                    echo "✅ Backend is healthy"

                    echo "Testing frontend..."
                    sh 'curl -f http://localhost:5173 || { echo "❌ Frontend health check failed"; exit 1; }'
                    echo "✅ Frontend is accessible"

                    echo "Testing database connectivity..."
                    sh "curl -f http://localhost:${PORT}/api/tasks || { echo '❌ Database connection failed'; exit 1; }"
                    echo "✅ Database is connected"
                }
            }
        }

        stage('Integration Tests') {
            steps {
                echo 'Running integration tests...'
                script {
                    echo "Creating test task..."
                    sh "curl -X POST http://localhost:${PORT}/api/tasks -H 'Content-Type: application/json' -d '{\"title\": \"Jenkins CI Test Task\", \"completed\": false}' -f || exit 1"

                    echo "Verifying task creation..."
                    sh "if curl http://localhost:${PORT}/api/tasks | grep 'Jenkins CI Test Task'; then echo '✅ Integration test passed'; else echo '❌ Task creation test failed'; exit 1; fi"
                }
            }
        }

        stage('Performance Check') {
            steps {
                echo '⚡ Running basic performance checks...'
                script {
                    echo "Checking API response time..."
                    sh "time curl -s http://localhost:${PORT}/api/tasks > /dev/null"
                    echo "Checking frontend load time..."
                    sh "time curl -s http://localhost:5173 > /dev/null"
                }
            }
        }
    }

    post {
        always {
            echo 'Cleaning up resources...'
            script {
                // Stops containers and cleans up without throwing errors if nothing is found
                sh 'docker compose down || true'
                sh 'docker ps -aq --filter "label=jenkins-test" | xargs -r docker rm -f'
                sh 'docker image prune -f || true'
            }
        }
        // ADD IT RIGHT HERE 👇
        failure {
            echo '❌ Pipeline failed! Fetching container status and logs...'
            script {
                // This shows us if the containers crashed (Exited 1)
                sh 'docker ps -a' 
                // This shows the actual error messages from inside the app
                sh 'docker compose logs --tail=50' 
            }
        }
        success {
            echo '✅ Pipeline completed successfully!'
        }
    }
}
