pipeline {
    agent any

    environment {
        // Variables for easier maintenance [cite: 1]
        BACKEND_IMAGE = "mern-backend:jenkins"
        FRONTEND_IMAGE = "mern-frontend:jenkins"
        DOCKER_REGISTRY = "hardiky99" 
        PORT = "5000"
        VITE_API_URL = "http://localhost:5000/api"
    }

    stages {
        stage('Checkout Code') {
            steps {
                echo 'Checking out source code from GitHub...' [cite: 1]
                script {
                    echo "Building commit: ${env.GIT_COMMIT}" [cite: 1]
                    echo "Branch: ${env.GIT_BRANCH}" [cite: 1]
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                echo 'Building Docker images...' [cite: 1]
                script {
                    // Build backend image [cite: 1]
                    echo "Building backend image: ${BACKEND_IMAGE}" [cite: 1]
                    sh "docker build -t ${BACKEND_IMAGE} ./server" [cite: 1]

                    // Build frontend image with API URL [cite: 1]
                    echo "Building frontend image: ${FRONTEND_IMAGE}" [cite: 1]
                    sh """
                        docker build -t ${FRONTEND_IMAGE} ./client \
                        --build-arg VITE_API_URL=${VITE_API_URL}
                    """ [cite: 1]

                    // Verify images were created [cite: 1]
                    sh "docker images | grep jenkins" [cite: 1]
                }
            }
        }

        stage('Start Application Services') {
            steps {
                echo 'Starting MERN application...' [cite: 1]
                // Injects the MONGO_URI secret you created in Jenkins
                withCredentials([string(credentialsId: 'MONGO_URI', variable: 'DB_URL')]) {
                    script {
                        // Create the .env file that was missing in your previous run 
                        sh "echo 'MONGO_URI=${DB_URL}' > ./server/.env"
                        sh "echo 'PORT=${PORT}' >> ./server/.env"

                        // Start the complete application stack [cite: 1]
                        sh 'docker compose up -d'
                        
                        // Wait for services to be ready [cite: 1]
                        echo "Waiting for services to start..." [cite: 1]
                        sleep(time: 30, unit: "SECONDS") [cite: 1]

                        // Show running containers [cite: 1]
                        sh 'docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Status}}"' [cite: 1]
                    }
                }
            }
        }

        stage('Health Check & Testing') {
            steps {
                echo 'Running health checks...' [cite: 1]
                script {
                    // Test backend API [cite: 1]
                    echo "Testing backend API..." [cite: 1]
                    sh "curl -f http://localhost:${PORT}/health || { echo '❌ Backend health check failed'; exit 1; }" [cite: 1]

                    // Test frontend [cite: 1]
                    echo "Testing frontend..." [cite: 1]
                    sh 'curl -f http://localhost:5173 || { echo "❌ Frontend health check failed"; exit 1; }' [cite: 1]
                }
            }
        }

        stage('Integration Tests') {
            steps {
                echo 'Running integration tests...' [cite: 1]
                script {
                    // Create a test task [cite: 1]
                    echo "Creating test task..." [cite: 1]
                    sh "curl -X POST http://localhost:${PORT}/api/tasks -H 'Content-Type: application/json' -d '{\"title\": \"Jenkins CI Test Task\", \"completed\": false}' -f || exit 1" [cite: 1]

                    // Verify task was created [cite: 1]
                    echo "Verifying task creation..." [cite: 1]
                    sh "if curl http://localhost:${PORT}/api/tasks | grep 'Jenkins CI Test Task'; then echo '✅ Integration test passed'; else echo '❌ Task creation test failed'; exit 1; fi" [cite: 1]
                }
            }
        }
    }

    post {
        always {
            echo 'Cleaning up resources...' [cite: 1]
            script {
                // Always clean up, regardless of build result [cite: 1]
                sh 'docker compose down || true' [cite: 1]
                // Fixed cleanup command using xargs -r to avoid errors when no containers exist 
                sh 'docker ps -aq --filter "label=jenkins-test" | xargs -r docker rm -f'
                sh 'docker image prune -f || true' [cite: 1]
            }
        }
        success {
            script {
                echo '✅ Pipeline completed successfully!' [cite: 1]
                sh "echo 'Build #${env.BUILD_NUMBER} succeeded at \$(date)'" [cite: 1]
            }
        }
        failure {
            echo '❌ Pipeline failed!' [cite: 1]
            script {
                // Capture logs for debugging [cite: 1]
                sh 'docker compose logs || true' [cite: 1, 16]
            }
        }
    }
}