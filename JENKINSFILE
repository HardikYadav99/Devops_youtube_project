pipeline {
    agent any

    environment {
        BACKEND_IMAGE = "mern-backend:jenkins"
        FRONTEND_IMAGE = "mern-frontend:jenkins"

        // 🔥 Correct internal Docker networking
        BACKEND_HOST = "backend"
        BACKEND_PORT = "5000"

        PORT = "5001" // only for host, not used in curl now
        VITE_API_URL = "http://backend:5000/api"
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo 'Checking out source code from GitHub...'
                script {
                    echo "Building commit: ${env.GIT_COMMIT}"
                    echo "Branch: ${env.GIT_BRANCH}"
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                echo 'Building Docker images...'
                script {
                    sh "docker build -t ${BACKEND_IMAGE} ./server"
                    sh "docker build -t ${FRONTEND_IMAGE} ./client --build-arg VITE_API_URL=${VITE_API_URL}"
                    sh "docker images | grep jenkins || true"
                }
            }
        }

        stage('Start Application Services') {
            steps {
                echo 'Starting MERN application...'
                script {

                    // No sudo in Jenkins container
                    sh 'chmod 666 /var/run/docker.sock || true'

                    sh 'pwd'
                    sh 'ls -la'
                    sh 'docker images'

                    withCredentials([string(credentialsId: 'MONGO_URI', variable: 'DB_URL')]) {

                        sh "echo 'MONGO_URI=${DB_URL}' > ./server/.env"
                        sh "echo 'PORT=5000' >> ./server/.env"

                        sh 'docker compose -f docker-compose.yml up -d'

                        echo "Waiting for services..."
                        sleep(time: 30, unit: "SECONDS")

                        sh 'docker compose ps'
                        sh 'docker ps'
                    }
                }
            }
        }

        stage('Health Check & Testing') {
            steps {
                echo 'Running health checks...'
                script {

                    echo "Testing backend..."
                    sh "curl -f http://${BACKEND_HOST}:${BACKEND_PORT}/health"

                    echo "Testing frontend..."
                    sh "curl -f http://frontend:5173"

                    echo "Testing DB..."
                    sh "curl -f http://${BACKEND_HOST}:${BACKEND_PORT}/api/tasks"

                    echo "✅ All health checks passed"
                }
            }
        }

        stage('Integration Tests') {
            steps {
                echo 'Running integration tests...'
                script {

                    sh """
                    curl -X POST http://${BACKEND_HOST}:${BACKEND_PORT}/api/tasks \
                    -H 'Content-Type: application/json' \
                    -d '{"title":"Jenkins CI Test Task","completed":false}'
                    """

                    sh """
                    if curl http://${BACKEND_HOST}:${BACKEND_PORT}/api/tasks | grep 'Jenkins CI Test Task';
                    then echo '✅ Integration test passed';
                    else echo '❌ Integration test failed'; exit 1;
                    fi
                    """
                }
            }
        }

        stage('Performance Check') {
            steps {
                echo '⚡ Performance test...'
                script {
                    sh "time curl -s http://${BACKEND_HOST}:${BACKEND_PORT}/api/tasks > /dev/null"
                    sh "time curl -s http://frontend:5173 > /dev/null"
                }
            }
        }
    }

    post {

        always {
            echo 'Cleaning up...'
            script {
                sh 'docker compose down || true'
                sh 'docker image prune -f || true'
            }
        }

        failure {
            echo '❌ Pipeline failed'
            script {
                sh 'docker ps -a'
                sh 'docker compose logs --tail=50 || true'
            }
        }

        success {
            echo '✅ Pipeline SUCCESS 🎉'
        }
    }
}